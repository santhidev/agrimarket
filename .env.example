# AgriMarket env vars. Copy the relevant lines into the package's own .env
# (apps/web/.env, packages/database/.env) — there is intentionally NO root .env
# (root .env is a monorepo anti-pattern; see ADR 0002 glossary).

# apps/web/.env — the Next.js app reads these
DATABASE_URL="postgresql://root:myPassword@localhost:5432/AgriMarket?schema=public"
ADMIN_PHONE="0899999999"
