# AgriMarket env vars. Each package that needs config has its own .env file
# (apps/web/.env.local) — there is intentionally NO root .env (root .env is a
# monorepo anti-pattern; see ADR 0002 glossary).

# apps/web/.env.local — the Next.js app reads these.
# Get the URL from `oss_host` in .insforge/project.json and the anon key via:
#   npx @insforge/cli secrets get ANON_KEY
NEXT_PUBLIC_INSFORGE_URL="https://<project>.<region>.insforge.app"
NEXT_PUBLIC_INSFORGE_ANON_KEY="<anon-key>"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Server-only, full-access API key (read from .insforge/project.json by the
# deployment; never expose to the browser). Used by admin-only routes and the
# edge function.
INSFORGE_API_KEY="<api-key>"
