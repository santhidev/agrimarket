@page "/"
@inherits AgriMarketComponentBase

<MudGrid Class="mb-3">
    <MudItem xs="12" md="6">
        <MudCard Style="height: 100%;">
            <MudCardContent>
                @if (!CurrentUser.IsAuthenticated)
                {
                    <MudText Typo="Typo.h5" Class="mb-2">@L["Welcome"]</MudText>
                    <MudText Typo="Typo.body1" Class="mud-text-secondary mb-2">@L["LongWelcomeMessage"]</MudText>
                    <MudButton Href="authentication/login" Variant="Variant.Filled" Color="Color.Primary" Class="mb-4"
                               StartIcon="@Icons.Material.Filled.Login">@L["Login"]</MudButton>
                }

                <MudText Typo="Typo.h6">Getting Started</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">Learn how to create and run a new web application using the application startup template.</MudText>
                <MudButton Href="https://docs.abp.io/en/abp/latest/getting-started" Target="_blank"
                           Variant="Variant.Filled" Color="Color.Primary" Class="mb-3">Getting Started</MudButton>

                <MudText Typo="Typo.h6">Web Application Development Tutorial</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">Learn how to build an ABP based web application named Acme.BookStore.</MudText>
                <MudButton Href="https://docs.abp.io/en/abp/latest/tutorials/book-store/part-1?UI=Blazor&DB=EF" Target="_blank"
                           Variant="Variant.Outlined" Color="Color.Primary">Explore Tutorial</MudButton>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudCard Style="height: 100%;">
            <MudCardContent>
                <MudText Typo="Typo.h6" Color="Color.Primary" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Groups" Class="me-1" /> Community
                </MudText>
                <MudText Typo="Typo.subtitle1" Class="mud-text-secondary">A unique community platform for <strong>ABP Lovers!</strong></MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">Explore all ABP users' experiences with the ABP Framework, discover articles and videos on how to use ABP, and join raffles for a chance to win surprise gifts!</MudText>
                <MudButton Href="https://community.abp.io/" Target="_blank"
                           Variant="Variant.Outlined" Color="Color.Primary" Class="mb-3">Join ABP Community</MudButton>

                <MudDivider Class="my-3" />

                <MudText Typo="Typo.h6" Color="Color.Primary" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.RssFeed" Class="me-1" /> Blog
                </MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">Find content on .NET development, cross-platform, ASP.NET application templates, ABP-related news, and more.</MudText>
                <MudButton Href="https://blog.abp.io/abp" Target="_blank"
                           Variant="Variant.Outlined" Color="Color.Primary">Visit Blog</MudButton>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

<MudGrid>
    <MudItem xs="12" lg="4">
        <MudCard Style="height: 100%;">
            <MudCardHeader>
                <MudText Typo="Typo.h6">More from ABP.IO</MudText>
            </MudCardHeader>
            <MudCardContent Class="pt-0">
                <MudList T="string" Dense="true">
                    <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Primary"
                                 Href="https://github.com/abpframework/abp/releases" Target="_blank">
                        Latest Release Logs
                    </MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Primary"
                                 Href="https://abp.io/video-courses/essentials" Target="_blank">
                        Video Courses
                    </MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Primary"
                                 Href="https://docs.abp.io/en/abp/latest/Samples/Index" Target="_blank">
                        Samples
                    </MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Primary"
                                 Href="https://abp.io/books" Target="_blank">
                        Books
                    </MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Primary"
                                 Href="https://abp.io/faq" Target="_blank">
                        FAQ
                    </MudListItem>
                </MudList>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" lg="8">
        <MudCard Style="height: 100%;">
            <MudCardHeader>
                <MudText Typo="Typo.h6">Follow us on Social Media</MudText>
            </MudCardHeader>
            <MudCardContent Class="pt-0">
                <MudGrid Spacing="0">
                    <MudItem xs="12" sm="6">
                        <MudList T="string" Dense="true">
                            <MudListItem Href="https://twitter.com/abpframework" Target="_blank"
                                         Icon="@Icons.Custom.Brands.Twitter" IconColor="Color.Primary">
                                X.com (Twitter)
                            </MudListItem>
                            <MudListItem Href="https://community.abp.io/discord" Target="_blank"
                                         Icon="@Icons.Custom.Brands.Discord" IconColor="Color.Primary">
                                Discord
                            </MudListItem>
                            <MudListItem Href="https://stackoverflow.com/questions/tagged/abp" Target="_blank"
                                         Icon="@Icons.Custom.Brands.StackOverflow" IconColor="Color.Primary">
                                Stack Overflow
                            </MudListItem>
                        </MudList>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudList T="string" Dense="true">
                            <MudListItem Href="@("https://www.youtube.com/@Volosoft")" Target="_blank"
                                         Icon="@Icons.Custom.Brands.YouTube" IconColor="Color.Error">
                                YouTube
                            </MudListItem>
                            <MudListItem Href="https://www.instagram.com/abpframework/" Target="_blank"
                                         Icon="@Icons.Custom.Brands.Instagram" IconColor="Color.Secondary">
                                Instagram
                            </MudListItem>
                            <MudListItem Href="https://github.com/abpframework/abp" Target="_blank"
                                         Icon="@Icons.Custom.Brands.GitHub" IconColor="Color.Dark">
                                GitHub
                            </MudListItem>
                        </MudList>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>
