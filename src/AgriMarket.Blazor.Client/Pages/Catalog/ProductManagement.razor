@page "/catalog/product-management"
@inherits AgriMarketComponentBase
@inject IProductAdminAppService ProductAdminService
@inject ISnackbar Snackbar

<MudText Typo="Typo.h4" Class="mb-4">จัดการสินค้า</MudText>

@if (_products == null)
{
    <MudProgressCircular Color="Color.Primary" Size="Size.Large" />
}
else
{
    <MudToolBar Class="mb-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenCreateDialog">
            เพิ่มสินค้า
        </MudButton>
    </MudToolBar>

    <MudTable Items="@_products" Hover="true" Elevation="2">
        <HeaderContent>
            <MudTh>ชื่อสินค้า</MudTh>
            <MudTh>หมวดหมู่</MudTh>
            <MudTh>หน่วย</MudTh>
            <MudTh>เกรด</MudTh>
            <MudTh>สถานะ</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd>@context.Category</MudTd>
            <MudTd>@context.Unit</MudTd>
            <MudTd>
                @if (context.HasStandardGrade)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text">มาตรฐาน</MudChip>
                }
                else
                {
                    <MudText Typo="Typo.body2">@string.Join(", ", context.Grades.Select(g => g.Name))</MudText>
                }
            </MudTd>
            <MudTd>
                @if (context.IsActive)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success">ใช้งาน</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Error">ปิดใช้งาน</MudChip>
                }
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info" Size="Size.Small"
                               OnClick="@(() => OpenEditDialog(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                               OnClick="@(() => DeleteProduct(context))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

<!-- Create/Edit Dialog -->
<MudDialog @bind-IsOpen="_dialogOpen" MaxWidth="MaxWidth.Medium" FullScreen="_isFullScreen">
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-4">
            @(_isEdit ? "แก้ไขสินค้า" : "เพิ่มสินค้าใหม่")
        </MudText>

        <EditForm Model="@_editingDto" OnValidSubmit="SaveProduct">
            <MudTextField @bind-Value="_editingDto.Name" Label="ชื่อสินค้า" Required="true"
                          Validation="@(ValidateRequired("กรุณากรอกชื่อสินค้า"))" Class="mb-3" />
            <MudTextField @bind-Value="_editingDto.Category" Label="หมวดหมู่" Required="true"
                          Validation="@(ValidateRequired("กรุณากรอกหมวดหมู่"))" Class="mb-3" />
            <MudTextField @bind-Value="_editingDto.Unit" Label="หน่วย (เช่น กก., ลูก)" Required="true"
                          Validation="@(ValidateRequired("กรุณากรอกหน่วย"))" Class="mb-3" />

            <MudGrid Class="mb-3">
                <MudItem xs="12" sm="6">
                    <MudCheckBox @bind-Value="_editingDto.RequiresColdChain" Label="ต้องการตู้เย็น" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudCheckBox @bind-Value="_editingDto.IsFragile" Label="แตกง่าย" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudCheckBox @bind-Value="_editingDto.IsStackable" Label="วางซ้อนได้" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField @bind-Value="_editingDto.ShelfLifeHours" Label="อายุการเก็บรักษา (ชม.)" Min="0" />
                </MudItem>
                <MudItem xs="12">
                    <MudNumericField @bind-Value="_editingDto.SortOrder" Label="ลำดับการแสดง" Min="0" />
                </MudItem>
            </MudGrid>

            @if (!_isEdit)
            {
                <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2">เกรดสินค้า (ถ้าไม่มี = มาตรฐาน)</MudText>
                @foreach (var grade in _editingDto.Grades ?? new())
                {
                    <MudCard Variant="Variant.Outlined" Class="mb-2 pa-2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudTextField @bind-Value="grade.Name" Label="ชื่อเกรด" Required Style="max-width: 150px" />
                            <MudTextField @bind-Value="grade.Description" Label="คำอธิบาย" Style="max-width: 200px" />
                            <MudNumericField @bind-Value="grade.SortOrder" Label="ลำดับ" Style="max-width: 80px" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                           OnClick="@(() => RemoveGrade(grade))" />
                        </MudStack>
                    </MudCard>
                }
                <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                           OnClick="AddGrade">
                    เพิ่มเกรด
                </MudButton>
            }

            @if (_isEdit && _editingProduct != null)
            {
                <MudDivider Class="my-4" />
                <MudText Typo="Typo.subtitle1" Class="mb-2">จัดการเกรด</MudText>

                @foreach (var grade in _editingProduct.Grades)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text" Class="mr-1 mb-1"
                             OnClose="@(() => DeleteGrade(grade.Id))" Closable="true">
                        @grade.Name
                    </MudChip>
                }

                <MudCard Variant="Variant.Outlined" Class="mt-2 pa-3">
                    <MudText Typo="Typo.body2" Class="mb-2">เพิ่มเกรดใหม่:</MudText>
                    <MudStack Row="true" AlignItems="AlignItems.End" Spacing="2">
                        <MudTextField @bind-Value="_newGrade.Name" Label="ชื่อเกรด" Required Style="max-width: 150px" />
                        <MudTextField @bind-Value="_newGrade.Description" Label="คำอธิบาย" Style="max-width: 200px" />
                        <MudNumericField @bind-Value="_newGrade.SortOrder" Label="ลำดับ" Style="max-width: 80px" />
                        <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add" OnClick="AddGradeToProduct">
                            เพิ่ม
                        </MudButton>
                    </MudStack>
                </MudCard>
            }

            <MudDialogActions Class="mt-4">
                <MudButton OnClick="CloseDialog">ยกเลิก</MudButton>
                <MudButton Type="Submit" Variant="Variant.Filled" Color="Color.Primary">
                    @(_isEdit ? "บันทึก" : "สร้าง")
                </MudButton>
            </MudDialogActions>
        </EditForm>
    </DialogContent>
</MudDialog>

@code {
    private List<ProductDto>? _products;
    private bool _dialogOpen;
    private bool _isEdit;
    private bool _isFullScreen;
    private ProductDto? _editingProduct;
    private CreateUpdateProductDto _editingDto = new();
    private CreateProductGradeDto _newGrade = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        var result = await ProductAdminService.GetListAsync();
        _products = result.Items.ToList();
    }

    // ── Create / Edit ─────────────────────────────────────────

    private void OpenCreateDialog()
    {
        _isEdit = false;
        _editingProduct = null;
        _editingDto = new CreateUpdateProductDto
        {
            IsStackable = true,
            Grades = new List<CreateProductGradeDto>()
        };
        _dialogOpen = true;
    }

    private void OpenEditDialog(ProductDto product)
    {
        _isEdit = true;
        _editingProduct = product;
        _editingDto = new CreateUpdateProductDto
        {
            Name = product.Name,
            Category = product.Category,
            Unit = product.Unit,
            RequiresColdChain = product.RequiresColdChain,
            IsFragile = product.IsFragile,
            ShelfLifeHours = product.ShelfLifeHours,
            IsStackable = product.IsStackable,
            SortOrder = product.SortOrder
        };
        _dialogOpen = true;
    }

    private void CloseDialog()
    {
        _dialogOpen = false;
    }

    private async Task SaveProduct()
    {
        try
        {
            if (_isEdit && _editingProduct != null)
            {
                await ProductAdminService.UpdateAsync(_editingProduct.Id, _editingDto);
                Snackbar.Add("บันทึกสำเร็จ", Severity.Success);
            }
            else
            {
                await ProductAdminService.CreateAsync(_editingDto);
                Snackbar.Add("สร้างสินค้าสำเร็จ", Severity.Success);
            }
            _dialogOpen = false;
            await LoadProducts();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"เกิดข้อผิดพลาด: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteProduct(ProductDto product)
    {
        try
        {
            await ProductAdminService.DeleteAsync(product.Id);
            Snackbar.Add("ปิดใช้งานสินค้าแล้ว", Severity.Success);
            await LoadProducts();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"เกิดข้อผิดพลาด: {ex.Message}", Severity.Error);
        }
    }

    // ── Grade management (inline) ─────────────────────────────

    private void AddGrade()
    {
        (_editingDto.Grades ??= new()).Add(new CreateProductGradeDto());
    }

    private void RemoveGrade(CreateProductGradeDto grade)
    {
        _editingDto.Grades?.Remove(grade);
    }

    private async Task AddGradeToProduct()
    {
        if (_editingProduct == null || string.IsNullOrWhiteSpace(_newGrade.Name)) return;

        try
        {
            await ProductAdminService.CreateGradeAsync(_editingProduct.Id, _newGrade);
            Snackbar.Add("เพิ่มเกรดสำเร็จ", Severity.Success);
            _newGrade = new CreateProductGradeDto();
            // Refresh the product data
            _editingProduct = await ProductAdminService.GetAsync(_editingProduct.Id);
            await LoadProducts();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"เกิดข้อผิดพลาด: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteGrade(Guid gradeId)
    {
        if (_editingProduct == null) return;

        try
        {
            await ProductAdminService.DeleteGradeAsync(_editingProduct.Id, gradeId);
            Snackbar.Add("ลบเกรดสำเร็จ", Severity.Success);
            _editingProduct = await ProductAdminService.GetAsync(_editingProduct.Id);
            await LoadProducts();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"เกิดข้อผิดพลาด: {ex.Message}", Severity.Error);
        }
    }

    // ── Validation helpers ────────────────────────────────────

    private static Func<string, IEnumerable<string>> ValidateRequired(string message)
    {
        return value => string.IsNullOrWhiteSpace(value) ? new[] { message } : Enumerable.Empty<string>();
    }
}
