@page "/catalog/products"
@inherits AgriMarketComponentBase
@inject IProductAppService ProductAppService

<MudText Typo="Typo.h4" Class="mb-4">สินค้าเกษตร</MudText>

@if (_products == null)
{
    <MudProgressCircular Color="Color.Primary" Size="Size.Large" Class="mt-4" />
    <MudText Align="Align.Center" Class="mt-2 mud-text-secondary">กำลังโหลด...</MudText>
}
else if (_products.Count == 0)
{
    <MudAlert Severity="Severity.Info" Class="mt-4">
        ยังไม่มีสินค้าในระบบ
    </MudAlert>
}
else
{
    <MudGrid>
        @foreach (var product in _products)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Class="mb-4">
                    <MudCardHeader>
                        <MudCardHeaderContent>
                            <MudText Typo="Typo.h6">@product.Name</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text" Class="mt-1">
                                @product.Category
                            </MudChip>
                        </MudCardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">
                            หน่วย: @product.Unit
                        </MudText>

                        @if (product.HasStandardGrade)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text" Class="mt-2">
                                มาตรฐาน
                            </MudChip>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Class="mt-2">เกรด:</MudText>
                            <div Class="mt-1">
                                @foreach (var grade in product.Grades)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text" Class="mr-1 mb-1">
                                        @grade.Name
                                    </MudChip>
                                }
                            </div>
                        }

                        @if (product.RequiresColdChain || product.IsFragile)
                        {
                            <MudDivider Class="my-2" />
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                @if (product.RequiresColdChain)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                                        ตู้เย็น
                                    </MudChip>
                                }
                                @if (product.IsFragile)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                                        แตกง่าย
                                    </MudChip>
                                }
                            </MudStack>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private List<ProductDto>? _products;

    protected override async Task OnInitializedAsync()
    {
        var result = await ProductAppService.GetListAsync();
        _products = result.Items.ToList();
    }
}
