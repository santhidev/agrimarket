<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AgriMarket.Maui.Pages.HomePage"
             Title="หน้าหลัก">

    <ScrollView>
        <VerticalStackLayout
            Padding="30"
            Spacing="20"
            HorizontalOptions="Center"
            MaximumWidthRequest="500">

            <Label Text="AgriMarket"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#2E7D32"
                   HorizontalOptions="Center" />

            <Border BackgroundColor="#F1F8E9"
                   Padding="20"
                   StrokeThickness="0"
                   StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="8">
                    <Label Text="เข้าสู่ระบบสำเร็จ"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#2E7D32"
                           HorizontalOptions="Center" />
                    <Label Text="{Binding WelcomeText}"
                           FontSize="14"
                           HorizontalOptions="Center"
                           TextColor="Gray" />
                    </VerticalStackLayout>
            </Border>

            <Label Text="หน้านี้จะพัฒนาต่อใน Issue ถัดไป (Catalog, Demand, Offer...)"
                   FontSize="13"
                   TextColor="Gray"
                   HorizontalOptions="Center"
                   Margin="0,20,0,0" />

            <Button Text="ออกจากระบบ"
                    Clicked="OnLogoutClicked"
                    BackgroundColor="#D32F2F"
                    TextColor="White"
                    CornerRadius="8"
                    Margin="0,20,0,0" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
