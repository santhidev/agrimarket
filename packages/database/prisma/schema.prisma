// Prisma schema for AgriMarket.
// Single source of truth for the data model. Run `pnpm db:migrate` after edits.

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// AgriMarket user. Phone is the primary identifier (phone-as-username).
/// Maps to the `users` table from the PRD. Enum-typed fields (tier, kycStatus)
/// are stored as Int for MVP; @agrimarket/shared will hold the TS enums/zod.
model User {
  id         String   @id @default(cuid())
  phone      String   @unique
  /// CreditTier enum value (0=None, 1=Bronze, 2=Silver, 3=Gold). Admin-managed (Phase 2).
  tier       Int      @default(0)
  buyerScore Int      @default(0)
  sellerScore Int     @default(0)
  /// KycStatus enum value (0=None, 1=Pending, 2=Approved, 3=Rejected).
  kycStatus  Int      @default(0)
  isAdmin    Boolean  @default(false)
  isRider    Boolean  @default(false)
  isHubStaff Boolean  @default(false)
  hubId      String?
  createdAt  DateTime @default(now())

  @@map("users")
}
