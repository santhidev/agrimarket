{
  "name": "@agrimarket/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "test": "vitest run"
  },
  "dependencies": {
    "@agrimarket/shared": "workspace:*",
    "@prisma/adapter-pg": "^6.15.0",
    "@prisma/client": "^6.15.0",
    "ioredis": "^5.4.0",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.0",
    "prisma": "^6.15.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
